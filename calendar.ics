 JJJ0QgK4QegQIARAB&uact=5&oq=what+is+ICHRA%2FQSEHRA+Annual+Notice+for+Next+
 Plan+Year+%28Calendar-Year+Example%29&gs_lp=Egxnd3Mtd2l6LXNlcnAiTXdoYXQgaX
 MgSUNIUkEvUVNFSFJBIEFubnVhbCBOb3RpY2UgZm9yIE5leHQgUGxhbiBZZWFyIChDYWxlbmRh
